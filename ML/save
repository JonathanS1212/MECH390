def is_constant(series, cv_threshold=0.01):
    std  = series.std()
    mean = series.mean()
    if pd.isna(std) or std == 0:    return True
    if mean == 0 or pd.isna(mean):  return std < 1e-10
    return (std / abs(mean)) < cv_threshold

