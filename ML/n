\newcommand{\drawSinusoidalBump}[3]{
    \begin{tikzpicture}[>=Stealth, thick]
        \def\L{#1} \def\A{#2} \def\off{#3}
        \draw (-1, 0) -- (0,0);
        \draw (\L, 0) -- (\L+1, 0);
        \draw[smooth, samples=100, domain=0:\L] 
            plot (\x, {\A/2 * (1 - cos(deg(2*pi*\x/\L)))});
        \draw[dashed, gray] (0,0) -- (\L,0);
        \draw[dashed, gray] (0,0) -- (0,-0.6);
        \draw[dashed, gray] (\L,0) -- (\L,-0.6);
        \draw[<->] (0,-0.4) -- (\L,-0.4) node[midway, fill=white, inner sep=1pt] {$L$};
        \draw[<->] ({\L/2}, 0) -- ({\L/2}, \A);
        \node at ({\L/2 + \off}, {\A/2}) [right] {$A$};
    \end{tikzpicture}
}

