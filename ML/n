        \node at (\currX+0.4, 1.8+\yZero) [right] {$k$};

        % 6. Mass and y(t) Output
        \node[draw, fill=gray!20, minimum width=\mW cm, minimum height=\mH cm, line width=1pt] 
            (Mass) at (\currX, 2.5+\yZero+0.4 + \mH/2) {$m$};
        
        \draw[->] (Mass.east) -- ($(Mass.east) + (0.4, 0)$) -- ($(Mass.east) + (0.4, 1.0)$) node[above] {$y(t)$};
        
        % Velocity u
        \draw[->, thick] (\currX+0.7, 0.9+\yZero) -- (\currX+1.3, 0.9+\yZero) node[right] {$u$};

    \end{tikzpicture}
}


